generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ────────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id        String     @id @default(cuid())
  name      String
  email     String     @unique
  password  String
  role      UserRole   @default(USER)
  status    UserStatus @default(PENDING)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  tradingAccounts TradingAccount[]
  tags            Tag[]
  blogPosts       BlogPost[]
  analysisReports TradeAnalysisReport[]
  tokenPurchases  TokenPurchase[]
}

// ─── Blog ────────────────────────────────────────────────────────────────────

model BlogPost {
  id          String    @id @default(cuid())
  authorId    String
  title       String
  slug        String    @unique
  excerpt     String?
  content     String
  published   Boolean   @default(false)
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  author User @relation(fields: [authorId], references: [id], onDelete: Cascade)

  @@index([authorId])
}

// ─── Accounts ────────────────────────────────────────────────────────────────

model TradingAccount {
  id          String     @id @default(cuid())
  userId      String
  name        String
  broker      String?
  marketType  MarketType
  currency    String     @default("USD")
  balance     Float      @default(0)
  description String?
  isActive    Boolean    @default(true)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  user            User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades          Trade[]
  transactions    AccountTransaction[]
  analysisReports TradeAnalysisReport[]
  tokenPurchases  TokenPurchase[]
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
}

model AccountTransaction {
  id         String          @id @default(cuid())
  accountId  String
  type       TransactionType
  amount     Float
  note       String?
  occurredAt DateTime        @default(now())
  createdAt  DateTime        @default(now())

  account TradingAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
}

// ─── Trades ──────────────────────────────────────────────────────────────────

model Trade {
  id        String      @id @default(cuid())
  accountId String
  symbol    String
  direction Direction
  status    TradeStatus @default(OPEN)
  entryMode EntryMode   @default(SINGLE)

  openTime   DateTime
  closeTime  DateTime?
  openPrice  Float
  closePrice Float?

  // Forex / Commodity
  lotSize Float?
  swap    Float  @default(0)

  // Multi-layer (forex/commodity)
  priceRangeHigh Float?
  priceRangeLow  Float?
  layerCount     Int?

  // Stocks (IDX / US)
  quantity  Float?
  buyFee    Float  @default(0)
  sellFee   Float  @default(0)
  taxAmount Float  @default(0)
  dividend  Float  @default(0)

  // Crypto futures
  leverage    Float?
  marginMode  MarginMode?
  fundingRate Float?

  // P&L
  grossProfit Float?
  commission  Float  @default(0)
  netProfit   Float?
  rMultiple   Float?
  pips        Float?

  // Risk management
  stopLoss    Float?
  takeProfit  Float?
  riskPercent Float?

  // For MULTI_ASSET accounts — which asset type this specific trade is
  tradeMarketType MarketType?

  // Analysis
  setup String?
  notes String?

  // Psychology
  emotionBefore  Int?
  emotionAfter   Int?
  holdingMinutes Int?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  account     TradingAccount    @relation(fields: [accountId], references: [id], onDelete: Cascade)
  tags        TradeTag[]
  screenshots TradeScreenshot[]
}

model TradeScreenshot {
  id      String  @id @default(cuid())
  tradeId String
  url     String
  caption String?

  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)
}

// ─── Tags ────────────────────────────────────────────────────────────────────

model Tag {
  id     String @id @default(cuid())
  userId String
  name   String
  color  String @default("#6366f1")

  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  trades TradeTag[]

  @@unique([userId, name])
}

model TradeTag {
  tradeId String
  tagId   String

  trade Trade @relation(fields: [tradeId], references: [id], onDelete: Cascade)
  tag   Tag   @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([tradeId, tagId])
}

// ─── Economic Calendar ───────────────────────────────────────────────────────

model EventAnalysis {
  id          String   @id @default(cuid())
  externalId  String   @unique
  summary     String
  bias        String
  instruments String[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model TradeAnalysisReport {
  id            String      @id @default(cuid())
  userId        String
  accountId     String
  period        String      // "YYYY-MM" (WIB) — bulan yang dianalisis
  headline      String
  content       Json        // { overview, strengths[], weaknesses[], recommendations[] }
  statsSnapshot Json        // snapshot angka kunci yang dikirim ke AI
  tokenSource   TokenSource @default(FREE)
  createdAt     DateTime    @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  account TradingAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, period])
}

enum TokenSource {
  FREE
  PURCHASED
}

enum TokenPurchaseStatus {
  PENDING
  APPROVED
  REJECTED
}

model TokenPurchase {
  id        String              @id @default(cuid())
  userId    String
  accountId String
  quantity  Int
  status    TokenPurchaseStatus @default(PENDING)
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  account TradingAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId, status])
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum MarketType {
  FOREX
  COMMODITY
  STOCK_IDX
  STOCK_US
  CRYPTO_SPOT
  CRYPTO_FUTURES
  MULTI_ASSET
}

enum Direction {
  LONG
  SHORT
}

enum TradeStatus {
  OPEN
  CLOSED
}

enum EntryMode {
  SINGLE
  MULTI_LAYER
}

enum MarginMode {
  ISOLATED
  CROSS
}

enum Impact {
  HIGH
  MEDIUM
  LOW
  HOLIDAY
}

